# ===== CONTROL DE FASES DEL SLOT =====
# Copia este archivo como .env y rellena con tus datos reales

# Tu ID numérico de Telegram (búscalo con @userinfobot)
TELEGRAM_OWNER_ID=123456789

# Ruta al archivo JSON de service account de Firebase
# Descárgalo desde: Firebase Console > Configuración > Cuentas de servicio > Generar nueva clave privada
FIREBASE_CRED_PATH=firebase_service_account.json

# URL de tu Realtime Database de Firebase
# Encuéntrala en: Firebase Console > Realtime Database > URL arriba
FIREBASE_DB_URL=https://tu-proyecto-default-rtdb.firebaseio.com

# ===== PASOS PARA CONFIGURAR =====
#
# 1. VE A: https://console.firebase.google.com/
# 2. Selecciona tu proyecto (gen-lang-client-0744582882 u otro)
# 3. Activa Realtime Database si no está activa:
#    - Build > Realtime Database > Crear base de datos
#    - Modo: "modo de prueba" (luego aseguramos reglas)
# 4. Copia la URL de la base de datos (arriba de la consola)
# 5. Ve a Configuración > Cuentas de servicio
# 6. Haz clic en "Generar nueva clave privada"
# 7. Guarda el JSON descargado como firebase_service_account.json
# 8. En Render: añade FIREBASE_DB_URL y TELEGRAM_OWNER_ID como env vars
# 9. Sube el JSON como archivo secreto o copia su contenido en una env var
#
# ===== CREDENCIALES WEB (para index.html y bonus_slot.html) =====
# Estas van DENTRO de los archivos HTML (reemplaza los YOUR_...)
# Encuéntralas en: Firebase Console > Configuración > General > Tu app web
#
# apiKey: "AIza..."
# authDomain: "tu-proyecto.firebaseapp.com"
# databaseURL: "https://tu-proyecto-default-rtdb.firebaseio.com"
# projectId: "tu-proyecto"
# storageBucket: "tu-proyecto.appspot.com"
# messagingSenderId: "123..."
# appId: "1:123:web:abc..."
#
# ===== REGLAS DE SEGURIDAD FIREBASE =====
# Pega esto en Realtime Database > Reglas:
#
# {
#   "rules": {
#     "slot_config": {
#       ".read": true,
#       ".write": "auth != null"
#     }
#   }
# }
#
# Esto permite que:
# - Cualquiera puede LEER (la web del slot)
# - Solo autenticados pueden ESCRIBIR (el bot con service account)
