# ============================================================
#  C8L BOT SERVER — Variables de entorno
#  Copia este archivo a .env.local para desarrollo local
# ============================================================

# ------------------------------------------------------------
#  OPCIÓN A: URL manual del tunnel (la más simple)
#  Copia la URL que muestra start.sh al arrancar y pégala aquí.
#  En Vercel: Settings → Environment Variables → NEXT_PUBLIC_SUNO_API_URL
# ------------------------------------------------------------
NEXT_PUBLIC_SUNO_API_URL=https://TU-TUNNEL.trycloudflare.com

# ------------------------------------------------------------
#  OPCIÓN B: Auto-descubrimiento (RECOMENDADO — no tocar nada)
#  Deja NEXT_PUBLIC_SUNO_API_URL vacía y configura solo esto:
#  El frontend llamará a /api/bot-url que contacta el VPS y
#  obtiene la URL del tunnel automáticamente.
#
#  En Vercel: Settings → Environment Variables → SUNO_VPS_URL
#  Nota: Esta variable NO tiene prefijo NEXT_PUBLIC_ a propósito
#  (es privada — no se expone al browser, solo al servidor Vercel)
# ------------------------------------------------------------
SUNO_VPS_URL=http://168.231.101.139:8080

# ------------------------------------------------------------
#  OTRAS VARIABLES DEL BOT (en el VPS, en config.py o .env)
# ------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=tu_token_aqui
# ADMIN_CHAT_ID=tu_chat_id
# GROUP_CHAT_ID=id_del_grupo
# OPENROUTER_API_KEY=tu_key
# TUNNEL_URL=                  # Se auto-rellena via start.sh — no tocar
