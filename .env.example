# ============================================================
#  C8L BOT SERVER — Variables de entorno
#  
#  INSTRUCCIONES:
#  - Para desarrollo local: copia a .env y rellena tus valores
#  - Para Render.com: configura en Dashboard → Environment
#  - Para Vercel: configura en Settings → Environment Variables
#  - NUNCA subas el archivo .env real a GitHub
# ============================================================

# --------------- TELEGRAM (REQUERIDO) ---------------
TELEGRAM_BOT_TOKEN=tu_token_de_botfather
ADMIN_CHAT_ID=tu_chat_id_numerico
GROUP_CHAT_ID=-1002476372487
BOT_NAME=leon_leo_bot

# --------------- GROQ — IA GRATIS (REQUERIDO) ---------------
# Obtener gratis en: https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_key_aqui

# --------------- OPENROUTER (BACKUP — OPCIONAL) ---------------
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu_key_aqui

# --------------- NVIDIA (BACKUP — OPCIONAL) ---------------
NVIDIA_API_KEY=nvapi-tu_key_aqui

# --------------- HUGGINGFACE — IMAGENES GRATIS ---------------
# Obtener gratis en: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_tu_token_aqui

# --------------- GOOGLE GEMINI (OPCIONAL) ---------------
GEMINI_API_KEY=AIzaSy_tu_key_aqui
GEMINI_ENABLED=false

# --------------- WHATSAPP CLOUD API (OPCIONAL) ---------------
WHATSAPP_TOKEN=tu_token_meta
WHATSAPP_PHONE_ID=tu_phone_id
WHATSAPP_BUSINESS_ID=tu_business_id
WHATSAPP_VERIFY_TOKEN=c8l_verify_2024

# --------------- SUNO AI — MUSICA (OPCIONAL) ---------------
# Obtener de suno.com → DevTools → document.cookie
# Se renueva cada ~7 dias
SUNO_COOKIE=tu_cookie_suno_completa

# --------------- MUSICAPI.AI (OPCIONAL) ---------------
MUSICAPI_KEY=tu_key_musicapi

# --------------- POLLINATIONS — VIDEO/IMAGEN GRATIS ---------------
POLLINATIONS_API_KEY=tu_key_pollinations

# --------------- DESIGN STUDIO (OPCIONAL) ---------------
PHOTOROOM_API_KEY=
REMOVEBG_API_KEY=

# --------------- HERMES BOT (OPCIONAL) ---------------
HERMES_BOT_TOKEN=tu_token_hermes

# --------------- FRONTEND (VERCEL) ---------------
# URL del backend en Render (se configura en Vercel)
NEXT_PUBLIC_API_URL=https://c8l-bot-server.onrender.com
# URL del frontend (se configura en Render)
C8L_WEB_URL=https://c8l-agency.vercel.app

# --------------- SERVER ---------------
PORT=8080
