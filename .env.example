# ===========================================================================
#  ⚡ C8L ANTIGRAVITY v5.0 — Variables de Entorno
#  Copia a .env y rellena con tus valores REALES
#  NUNCA subir el .env a git (ya esta en .gitignore)
# ===========================================================================

# ===========================================================================
# 🔑 REQUERIDAS (sin estas el bot NO arranca)
# ===========================================================================
TELEGRAM_BOT_TOKEN=tu_token_de_botfather
ADMIN_CHAT_ID=tu_chat_id_numerico
GROQ_API_KEY=gsk_tu_key_de_groq

# ===========================================================================
# ⚡ API ROUTER INFINITO — Proveedores (cuantos mas, menos limites)
# ===========================================================================

# Prioridad 1: Groq (30 rpm, gratis)
# Ya configurado arriba con GROQ_API_KEY

# Prioridad 2: OpenRouter (20 rpm, modelos gratis ilimitados)
OPENROUTER_API_KEY=sk-or-v1-tu_key

# Prioridad 3: Google Gemini (15 rpm, gratis)
GEMINI_API_KEY=tu_key_de_google_ai_studio
GEMINI_ENABLED=true

# Prioridad 4: NVIDIA (10 rpm, gratis)
NVIDIA_API_KEY=nvapi-tu_key

# Prioridad 5: HuggingFace (30 rpm, gratis)
HUGGINGFACE_TOKEN=hf_tu_token

# Prioridad 6: Cloudflare Workers AI (50 rpm, gratis)
CLOUDFLARE_ACCOUNT_ID=tu_account_id
CLOUDFLARE_AI_TOKEN=tu_token_cloudflare

# ===========================================================================
# 📱 TELEGRAM
# ===========================================================================
BOT_NAME=leon_leo_bot
GROUP_CHAT_ID=-100xxxxxxxxxx

# ===========================================================================
# 📞 WHATSAPP (opcional — segundo canal)
# ===========================================================================
WHATSAPP_TOKEN=tu_token_meta
WHATSAPP_PHONE_ID=tu_phone_id
WHATSAPP_BUSINESS_ID=tu_business_id
WHATSAPP_VERIFY_TOKEN=c8l_verify_2024

# ===========================================================================
# 🎵 MUSICA
# ===========================================================================
SUNO_COOKIE=tu_cookie_suno
MUSICAPI_KEY=tu_key_musicapi

# ===========================================================================
# 🎬 MEDIA / VIDEO / IMAGENES
# ===========================================================================
POLLINATIONS_API_KEY=tu_key_pollinations
AGNES_API_KEY=tu_key_agnes
CLOUDINARY_URL=cloudinary://key:secret@cloud
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_cloudinary_key
CLOUDINARY_API_SECRET=tu_cloudinary_secret

# ===========================================================================
# 🛡️ HERMES BOT (watchdog — mantiene el bot vivo)
# ===========================================================================
HERMES_BOT_TOKEN=tu_token_hermes_de_botfather

# ===========================================================================
# 🐙 GITHUB (para que el bot modifique código en vivo)
# ===========================================================================
GITHUB_TOKEN=ghp_tu_token_personal_con_repo_scope
GITHUB_OWNER=leovela69
GITHUB_REPO=c8l-bot-server

# ===========================================================================
# 🚀 RENDER (para control de deploys desde Telegram)
# ===========================================================================
RENDER_API_KEY=rnd_tu_api_key_de_render_dashboard
RENDER_SERVICE_ID=srv-tu_service_id
BOT_HEALTH_URL=https://c8l-bot-server.onrender.com/health

# ===========================================================================
# 🌉 SAYAN BRIDGE (conexion con bots aliados)
# ===========================================================================
BRIDGE_SECRET=tu_secreto_compartido
SAYAN_API_URL=https://sayan-bot1.onrender.com

# ===========================================================================
# 🌐 CLOUDFLARE (cache, DNS, AI Gateway)
# ===========================================================================
CF_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/tu_account/tu_gateway
CF_AI_GATEWAY_ID=tu_gateway_id
CF_WORKERS_URL=
CF_KV_NAMESPACE=
CF_KV_TOKEN=

# ===========================================================================
# 🔧 HERRAMIENTAS / SKILLS
# ===========================================================================
PHOTOROOM_API_KEY=
REMOVEBG_API_KEY=
GNEWS_API_KEY=tu_key_gnews
SKILLSCAN_API_KEY=

# ===========================================================================
# 🌐 URLS
# ===========================================================================
C8L_WEB_URL=https://c8l-agency.vercel.app

# ===========================================================================
# ⚙️ SERVIDOR
# ===========================================================================
PORT=8080
HERMES_PORT=8081

# ===========================================================================
# 🧠 ANTIGRAVITY — Feature Flags
# ===========================================================================
ANTIGRAVITY_ENABLED=true
TRIAGE_3LAYER=true
MEMORY_V4=true
SKILLS_V4=true
EVENT_BUS=true
SCHEDULER_ENABLED=true
PROACTIVE_ENABLED=true
MIXTURE_ENABLED=true

# ===========================================================================
# 🔊 AUDIO / VISION
# ===========================================================================
EDGE_TTS_VOICE=es-MX-DaliaNeural
WHISPER_MODEL=whisper-large-v3-turbo
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
GROQ_VISION_LIGHT=llama-3.2-11b-vision-preview
GROQ_LIGHT_MODEL=llama-3.2-1b-preview

# ===========================================================================
# 📊 CAPACIDAD TOTAL DEL API ROUTER (con todas las keys activas):
#
#   Groq:        30 rpm  |  14,400/dia
#   OpenRouter:  20 rpm  |  ilimitado (modelos gratis)
#   Gemini:      15 rpm  |  1,500/dia
#   NVIDIA:      10 rpm  |  5,000/dia
#   HuggingFace: 30 rpm  |  ilimitado
#   Cloudflare:  50 rpm  |  10,000/dia
#   ─────────────────────────────────
#   TOTAL:      175 rpm  |  ~45,000+/dia
#
#   = EFECTIVAMENTE ILIMITADO para uso real ⚡
# ===========================================================================
